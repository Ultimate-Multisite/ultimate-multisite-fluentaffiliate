{
  "name": "ultimate-multisite/multisite-ultimate-fluentaffiliate",
  "url": "https://multisiteultimate.com",
  "description": "FluentAffiliate Integration for Multisite Ultimate \u2014 recurring commission tracking for WaaS memberships.",
  "version": "1.0.0",
  "authors": [
    {
      "name": "David Stone",
      "homepage": "https://github.com/superdav42"
    }
  ],
  "license": [
    "GPL-2.0-or-later"
  ],
  "autoload": {
    "classmap": [
      "inc"
    ]
  },
  "type": "wordpress-plugin",
  "require": {
    "php": ">=7.4.1",
    "ext-json": "*",
    "yahnis-elsts/plugin-update-checker": "^5.6",
    "wearerequired/traduttore-registry": "^2.0"
  },
  "require-dev": {
    "composer/installers": "^1.9.0",
    "phpunit/phpunit": "^9.6.22",
    "yoast/phpunit-polyfills": "^1.1.3",
    "woocommerce/woocommerce-sniffs": "^1.0.0",
    "fakerphp/faker": "^1.24",
    "rector/rector": "^2.0.8",
    "szepeviktor/phpstan-wordpress": "^2.0.1",
    "phpstan/extension-installer": "^1.1",
    "wp-cli/wp-cli-bundle": "^2.12"
  },
  "config": {
    "platform": {
      "php": "7.4.1"
    },
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true,
      "php-http/discovery": true
    },
    "optimize-autoloader": true,
    "classmap-authoritative": true
  },
  "archive": {
    "exclude": [
      "tests",
      "phpunit.xml.dist",
      "composer.lock",
      ".phpcs.xml.dist",
      ".idea",
      "node_modules",
      ".gitignore",
      ".phpunit.result.cache",
      "package.json",
      "package-lock.json",
      "phpstan.neon.dist",
      "rector.php",
      ".github"
    ]
  },
  "autoload-dev": {
    "files": [
      "vendor/php-stubs/wordpress-stubs/wordpress-stubs.php"
    ]
  }
}
